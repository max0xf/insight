## Copy this file to .env.local in the same folder and set real values.
## AIRBYTE_CONFIG is destination-postgres config JSON without schema.
## Schema/namespace is provided as required argument to destination.sh.
AIRBYTE_DESTINATION_CONFIG={"host":"127.0.0.1","port":5432,"database":"monitor","username":"monitor_user","password":"monitor_password","ssl_mode":{"mode":"disable"},"use_1s1t_format":true,"raw_data_schema":"airbyte_internal"}
